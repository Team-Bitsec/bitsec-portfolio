---
import '../styles/global.css';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer.astro';
import MobileStickyBar from '../components/ui/MobileStickyBar.astro';
import { ViewTransitions } from 'astro:transitions';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
	title?: string;
    description?: string;
    image?: string;
    faqSchema?: {question: string; answer: string}[];
}

const { 
    title = "Bitsec - Digital Service Agency",
    description = "Top Digital Agency in Bangladesh. We build ultra-fast websites, mobile apps, and highly secure digital solutions for ambitious brands.",
    image = "/og-image.jpg",
    faqSchema = []
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const basePath = import.meta.env.BASE_URL;
let currentPath = Astro.url.pathname;
if (basePath !== '/' && currentPath.startsWith(basePath)) {
    currentPath = currentPath.substring(basePath.length - 1);
    if (!currentPath.startsWith('/')) currentPath = '/' + currentPath;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://bitsec.agency';

const getFullUrl = (path: string) => {
    const b = basePath.endsWith('/') ? basePath.slice(0, -1) : basePath;
    return siteOrigin + b + (path === '/' ? '' : path);
};

const bnPath = currentPath.startsWith('/en') ? currentPath.replace(/^\/en/, '') || '/' : currentPath;
const enPath = currentPath.startsWith('/en') ? currentPath : '/en' + (currentPath === '/' ? '' : currentPath);

const hreflangBN = getFullUrl(bnPath);
const hreflangEN = getFullUrl(enPath);

const orgSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness"],
  "name": "BitsecIT",
  "url": siteOrigin,
  "logo": siteOrigin + "/logo.png",
  "description": "Bangladesh-এর সেরা ডিজিটাল সার্ভিস কোম্পানি। Web Development, App Development, Graphics Design ও Penetration Testing।",

  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+8801805543229",
    "contactType": "customer service",
    "email": "helpline.bitsec@gmail.com",
    "availableLanguage": ["Bengali", "English"]
  },
  "sameAs": [
    "https://www.linkedin.com/company/bitsec-it",
    "https://www.youtube.com/@BitsecIT",
    "https://www.instagram.com/bitsecit"
  ]
};

const faqJsonLd = faqSchema.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqSchema.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
} : null;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<link rel="apple-touch-icon" href="/logo.png" />
		<meta name="theme-color" content="#0057FF" />
		<meta name="generator" content={Astro.generator} />
        
        {/* Canonical URL */}
        <link rel="canonical" href={canonicalURL} />

        {/* Hreflang for Bilingual SEO */}
        <link rel="alternate" hreflang="bn" href={hreflangBN} />
        <link rel="alternate" hreflang="en" href={hreflangEN} />
        <link rel="alternate" hreflang="x-default" href={hreflangBN} />

        {/* Primary Meta Tags */}
		<title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={description} />

        {/* Open Graph / Facebook */}
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, Astro.url)} />

        {/* Twitter */}
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(image, Astro.url)} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Noto+Sans+Bengali:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

		<ViewTransitions />

		{/* Organization + LocalBusiness Schema */}
		<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
		{faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

		<script is:inline define:vars={{ basePath }}>
			// Theme preference
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
		
			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
			window.localStorage.setItem('theme', theme);

			// Language preference — default: English ('en')
			(function() {
				const savedLang = localStorage.getItem('lang');
				let currentPath = window.location.pathname;
				
				if (basePath !== '/' && currentPath.startsWith(basePath)) {
					currentPath = currentPath.substring(basePath.length - 1);
					if (!currentPath.startsWith('/')) currentPath = '/' + currentPath;
				}

				const isEnPath = currentPath.startsWith('/en') || currentPath === '/en';
				const isBnPath = !isEnPath;

				const redirect = (path) => {
					const b = basePath.endsWith('/') ? basePath.slice(0, -1) : basePath;
					window.location.replace((b + (path === '/' ? '' : path)) || '/');
				};

				if (!savedLang) {
					localStorage.setItem('lang', 'en');
					if (isBnPath) {
						const enPath = currentPath === '/' ? '/en' : '/en' + currentPath;
						redirect(enPath);
					}
				} else {
					if (savedLang === 'bn' && isEnPath) {
						const bnPath = currentPath.replace(/^\/en/, '') || '/';
						redirect(bnPath);
					} else if (savedLang === 'en' && isBnPath) {
						const enPath = currentPath === '/' ? '/en' : '/en' + currentPath;
						redirect(enPath);
					}
				}
			})();
		</script>
	</head>
	<body class="flex flex-col min-h-screen" style="padding-bottom: env(safe-area-inset-bottom);">
		<Navigation client:load lang={lang} currentPath={currentPath} basePath={basePath} />
		<main class="flex-grow pt-20">
			<slot />
		</main>
		<Footer />
		<MobileStickyBar lang={lang} />

		{/* Desktop Floating WhatsApp FAB — hidden on mobile (MobileStickyBar handles that) */}
		<a
			href="https://wa.me/8801805543229"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Chat on WhatsApp"
			class="hidden md:flex fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full shadow-xl items-center justify-center hover:scale-110 hover:shadow-2xl hover:shadow-[#25D366]/40 transition-all duration-300 group"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="white">
				<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
			</svg>
			{/* Tooltip */}
			<span class="absolute right-16 whitespace-nowrap bg-gray-900 text-white text-xs font-medium px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
				{lang === 'en' ? 'Chat on WhatsApp' : 'হোয়াটসঅ্যাপে কথা বলুন'}
			</span>
		</a>
	</body>
</html>

