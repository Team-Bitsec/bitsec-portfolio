---
import { getLangFromUrl, useTranslatedPath } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const services = [
  {
    title: lang === 'en' ? 'Web Development' : 'ওয়েব ডেভেলপমেন্ট',
    description: lang === 'en' ? 'Custom, SEO-optimized, and lightning-fast websites.' : 'কাস্টম, এসইও-অপ্টিমাইজড এবং অত্যন্ত দ্রুতগতির ওয়েবসাইট।',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="url(#svc-web-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform transition-all duration-300 group-hover:scale-110 group-hover:-rotate-3 drop-shadow-md"><defs><linearGradient id="svc-web-grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#0057FF" /><stop offset="100%" stop-color="#00C2A8" /></linearGradient></defs><rect width="20" height="14" x="2" y="3" rx="2" ry="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>`,
    link: '/services/web-development'
  },
  {
    title: lang === 'en' ? 'App Development' : 'অ্যাপ ডেভেলপমেন্ট',
    description: lang === 'en' ? 'High-performance mobile applications for iOS & Android.' : 'iOS ও Android এর জন্য হাই-পারফরম্যান্স মোবাইল অ্যাপ।',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="url(#svc-app-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform transition-all duration-300 group-hover:scale-110 group-hover:rotate-3 drop-shadow-md"><defs><linearGradient id="svc-app-grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#00C2A8" /><stop offset="100%" stop-color="#0057FF" /></linearGradient></defs><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
    link: '/services/app-development'
  },
  {
    title: lang === 'en' ? 'Graphics Design' : 'গ্রাফিক্স ডিজাইন',
    description: lang === 'en' ? 'Stunning visuals, branding, and UI/UX design.' : 'আকর্ষণীয় ভিজ্যুয়াল, ব্র্যান্ডিং এবং UI/UX ডিজাইন।',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="url(#svc-design-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform transition-all duration-300 group-hover:scale-110 group-hover:-rotate-6 drop-shadow-md"><defs><linearGradient id="svc-design-grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#FF00A0" /><stop offset="100%" stop-color="#FF5A00" /></linearGradient></defs><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>`,
    link: '/services/graphics-design'
  },
  {
    title: lang === 'en' ? 'Penetration Testing' : 'পেনেট্রেশন টেস্টিং',
    description: lang === 'en' ? 'Advanced security audits to keep your applications safe.' : 'আপনার অ্যাপ্লিকেশন সুরক্ষিত রাখতে অ্যাডভান্সড সিকিউরিটি অডিট।',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="url(#svc-sec-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform transition-all duration-300 group-hover:scale-110 group-hover:rotate-6 drop-shadow-md"><defs><linearGradient id="svc-sec-grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#FF5A00" /><stop offset="100%" stop-color="#0057FF" /></linearGradient></defs><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    link: '/services/penetration-testing'
  }
];
---
<section class="py-24 bg-background relative overflow-hidden">
  <div class="absolute inset-0 bg-grid-white/[0.02] bg-[size:32px_32px]"></div>
  

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-3xl md:text-5xl font-extrabold bg-gradient-to-r from-[#0057FF] via-[#00C2A8] to-[#0057FF] bg-clip-text text-transparent mb-6 inline-block animate-gradient-shimmer pb-2">
        {lang === 'en' ? 'Our Services' : 'আমাদের সার্ভিসসমূহ'}
      </h2>
      <p class="text-lg text-text-secondary dark:text-gray-400 max-w-2xl mx-auto">
        {lang === 'en' ? 'We provide end-to-end digital solutions to help your business thrive.' : 'আপনার ব্যবসার প্রবৃদ্ধিতে আমরা এন্ড-টু-এন্ড ডিজিটাল সলিউশন প্রদান করি।'}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service, i) => (
        <a href={translatePath(service.link)} class="block group h-full" data-animate="fade-up" style={`--stagger: ${i * 0.12}s`}>
          <div class="bg-surface dark:bg-[#1C2128] p-8 rounded-2xl border border-border dark:border-[#30363D] h-full transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-primary/20 relative overflow-hidden group">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-primary/5 rounded-full blur-2xl transition-all duration-300 group-hover:bg-primary/15 group-hover:scale-150"></div>
            <div class="mb-6 relative z-10" set:html={service.icon}></div>
            <h3 class="text-xl font-bold text-text-primary dark:text-white mb-3 group-hover:text-primary transition-colors">{service.title}</h3>
            <p class="text-text-secondary dark:text-gray-400">{service.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // Respect prefers-reduced-motion
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const animEls = document.querySelectorAll('[data-animate="fade-up"]');

  if (prefersReduced) {
    // Skip animation — show immediately
    animEls.forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'none';
    });
  } else {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const stagger = parseFloat(getComputedStyle(el).getPropertyValue('--stagger') || '0');
          setTimeout(() => {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          }, stagger * 1000);
          revealObserver.unobserve(el);
        });
      },
      { threshold: 0.12 }
    );
    animEls.forEach((el) => {
      const h = el as HTMLElement;
      h.style.opacity = '0';
      h.style.transform = 'translateY(24px)';
      h.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      revealObserver.observe(h);
    });
  }
</script>

