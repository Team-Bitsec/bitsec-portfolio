---
import { getLangFromUrl, useTranslatedPath } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
---

<section class="py-20 bg-gradient-to-br from-[#0057FF] to-[#0040C0] dark:from-[#0f2847] dark:to-[#0D1117] relative overflow-hidden">
  {/* Decorative circles */}
  <div class="absolute top-0 left-0 w-72 h-72 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      
      {/* Left Text Content */}
      <div class="text-center lg:text-left">
        <div class="inline-flex flex-col items-center lg:items-start gap-2 mb-6">
          <div class="inline-block bg-white/20 text-white px-4 py-1.5 rounded-full text-sm font-semibold backdrop-blur-sm">
            🎁 {lang === 'en' ? '100% Free — No Commitment' : '১০০% বিনামূল্যে — কোনো বাধ্যবাধকতা নেই'}
          </div>
          <div class="text-white/70 text-sm font-medium">
            ✦ {lang === 'en' ? 'Limited slots available — book early' : 'সীমিত সুযোগ — আগে বুক করুন'}
          </div>
        </div>
        
        <h2 class="text-3xl md:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white via-[#CFF5EE] to-white mb-6 leading-tight pb-2 animate-gradient-shimmer">
          {lang === 'en'
            ? 'Get a Free Consultation Today'
            : 'আজই বিনামূল্যে পরামর্শ নিন'}
        </h2>
        
        <p class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl mx-auto lg:mx-0">
          {lang === 'en'
            ? 'Not sure where to start? Book a 15-minute free Zoom call with our experts. We\'ll analyze your needs and suggest the best solution.'
            : 'কোথা থেকে শুরু করবেন বুঝতে পারছেন না? আমাদের বিশেষজ্ঞের সাথে ১৫ মিনিটের ফ্রি Zoom কল বুক করুন। আমরা আপনার প্রয়োজন বিশ্লেষণ করে সেরা সমাধান বলব।'}
        </p>

        <div class="flex flex-wrap justify-center lg:justify-start gap-4 mb-10 text-white/70 text-sm font-medium">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-[#00C2A8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {lang === 'en' ? 'No strings attached' : 'কোনো শর্ত নেই'}
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-[#00C2A8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {lang === 'en' ? 'Expert advice' : 'বিশেষজ্ঞ পরামর্শ'}
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-[#00C2A8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {lang === 'en' ? 'Reply within 2 hours' : '২ ঘণ্টার মধ্যে রিপ্লাই'}
          </span>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href={translatePath('/contact')}
            class="inline-flex items-center justify-center font-bold rounded-xl transition-all duration-300 px-8 py-4 text-lg bg-white text-primary hover:bg-[#F3F4F6] shadow-[0_0_20px_rgba(255,255,255,0.3)] hover:shadow-[0_0_30px_rgba(255,255,255,0.5)] hover:-translate-y-1"
          >
            {lang === 'en' ? '📅 Book Free Consultation' : '📅 ফ্রি কনসালটেশন বুক করুন'}
          </a>
          <a
            href={`https://wa.me/8801805543229?text=${encodeURIComponent(lang === 'en' ? 'Hi BitsecIT, I would like a free consultation.' : 'হ্যালো BitsecIT, আমি একটি ফ্রি কনসালটেশন নিতে চাই।')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-bold rounded-xl transition-all duration-300 px-8 py-4 text-lg border-2 border-white/40 text-white hover:bg-white/10 hover:-translate-y-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="mr-2">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {lang === 'en' ? 'WhatsApp Us' : 'হোয়াটসঅ্যাপ করুন'}
          </a>
        </div>
      </div>

      {/* Right UI Illustration */}
      <div class="hidden lg:block relative py-10 pl-8">
        <div class="absolute inset-0 bg-gradient-to-tr from-[#00C2A8]/20 to-transparent blur-3xl rounded-full"></div>
        <style is:global>
          @keyframes fcFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }
          @keyframes fcPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
          .fc-svg-float { animation: fcFloat 6s ease-in-out infinite; }
          .fc-svg-pulse { animation: fcPulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
          .fc-svg-float-alt { animation: fcFloat 5s ease-in-out infinite alternate; }
          .fc-svg-float-rev { animation: fcFloat 6s ease-in-out infinite alternate-reverse; }
        </style>
        <svg viewBox="0 0 500 500" class="w-full h-auto drop-shadow-2xl fc-svg-float" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="illustrationGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#00C2A8" />
              <stop offset="100%" stop-color="#3b82f6" />
            </linearGradient>
            <linearGradient id="glassProps" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="white" stop-opacity="0.1"/>
              <stop offset="100%" stop-color="white" stop-opacity="0"/>
            </linearGradient>
            <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="15" result="blur" />
              <feComposite in="SourceGraphic" in2="blur" operator="over" />
            </filter>
          </defs>
          
          <!-- Background geometric shapes -->
          <circle cx="250" cy="250" r="180" fill="url(#glassProps)" stroke="rgba(255,255,255,0.2)" stroke-width="1" />
          <path d="M 100 250 q 150 -150 300 0" fill="none" stroke="url(#illustrationGrad)" stroke-width="3" stroke-linecap="round" stroke-dasharray="10 15" class="fc-svg-pulse" />
          <path d="M 120 280 q 130 100 260 0" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" stroke-linecap="round" stroke-dasharray="5 10" class="fc-svg-pulse" style="animation-delay: 1s;" />
          
          <!-- Abstract Video Call / Meeting Window -->
          <rect x="90" y="140" width="320" height="220" rx="16" fill="rgba(15, 23, 42, 0.8)" stroke="rgba(255,255,255,0.1)" stroke-width="2" style="backdrop-filter: blur(10px);" />
          
          <!-- Inner Screen -->
          <rect x="110" y="160" width="280" height="150" rx="8" fill="#1e293b" />
          
          <!-- Expert Avatar -->
          <circle cx="200" cy="235" r="35" fill="url(#illustrationGrad)" />
          <circle cx="200" cy="220" r="14" fill="#fff" />
          <path d="M 175 260 q 25 -25 50 0" stroke="#fff" stroke-width="5" fill="none" stroke-linecap="round"/>
          
          <!-- Client Avatar -->
          <circle cx="300" cy="235" r="28" fill="#334155" />
          <circle cx="300" cy="225" r="11" fill="#cbd5e1" />
          <path d="M 283 255 q 17 -17 34 0" stroke="#cbd5e1" stroke-width="4" fill="none" stroke-linecap="round"/>
          
          <!-- Connection / Data Flow Line -->
          <line x1="240" y1="235" x2="265" y2="235" stroke="url(#illustrationGrad)" stroke-width="4" stroke-dasharray="8 6" />
          
          <!-- UI Elements -->
          <rect x="120" y="170" width="40" height="8" rx="4" fill="#475569" />
          
          <!-- Controls -->
          <circle cx="210" cy="335" r="12" fill="#ef4444" />
          <circle cx="250" cy="335" r="12" fill="#3b82f6" />
          <circle cx="290" cy="335" r="12" fill="#10b981" />
          
          <!-- Floating Notifications -->
          <!-- Top Left Notification -->
          <g class="fc-svg-float-alt" style="transform-origin: 150px 100px;">
            <rect x="60" y="80" width="120" height="40" rx="10" fill="#ffffff" filter="url(#glow)" />
            <circle cx="85" cy="100" r="8" fill="#10b981" />
            <rect x="105" y="95" width="50" height="6" rx="3" fill="#cbd5e1" />
            <rect x="105" y="105" width="30" height="4" rx="2" fill="#e2e8f0" />
          </g>
          
          <!-- Bottom Right Badge -->
          <g class="fc-svg-float-rev" style="transform-origin: 380px 380px;">
            <circle cx="380" cy="380" r="45" fill="url(#illustrationGrad)" filter="url(#glow)" />
            <path d="M 365 380 l 10 10 l 20 -20" stroke="#ffffff" fill="none" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
          </g>
          
          <!-- Small decorative stars/pluses -->
          <path d="M 420 180 v 16 m -8 -8 h 16" stroke="url(#illustrationGrad)" stroke-width="3" stroke-linecap="round" class="fc-svg-pulse" />
          <path d="M 80 320 v 10 m -5 -5 h 10" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" class="fc-svg-pulse" style="animation-delay: 2s;" />
        </svg>
      </div>

    </div>
  </div>
</section>
