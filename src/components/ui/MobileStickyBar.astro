---
export interface Props {
  lang: string;
}

const { lang } = Astro.props;

// For translation mappings
const whatsappText = lang === 'en' ? 'WhatsApp Us' : 'হোয়াটসঅ্যাপ করুন';
const quoteText = lang === 'en' ? 'Get a Quote' : 'কোটেশন নিন';
---

<div class="fixed bottom-0 left-0 right-0 z-50 bg-white/90 dark:bg-[var(--theme-surface-2)]/95 backdrop-blur-md border-t border-border dark:border-border shadow-[0_-10px_40px_rgba(0,0,0,0.1)] md:hidden transition-transform duration-300 transform translate-y-0" id="mobile-sticky-bar" style="padding-bottom: env(safe-area-inset-bottom);">
  <div class="flex gap-3 justify-center max-w-sm mx-auto p-3">
    
    <a href="https://wa.me/8801805543229" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 bg-[#25D366] text-white py-3 px-4 rounded-xl font-bold text-sm shadow-md hover:scale-[1.02] active:scale-95 transition-transform">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/>
      </svg>
      {whatsappText}
    </a>
    
    <a href={lang === 'en' ? '/contact' : '/contact'} class="flex-1 flex items-center justify-center gap-2 bg-gradient-to-r from-[#FF5A00] to-[#FF8F00] text-white py-3 px-4 rounded-xl font-bold text-sm shadow-md hover:scale-[1.02] active:scale-95 transition-transform">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 2L11 13"/>
        <path d="M22 2L15 22L11 13L2 9L22 2Z"/>
      </svg>
      {quoteText}
    </a>
    
  </div>
</div>

<script is:inline>
  // Hide sticky bar when footer is reached to avoid overlap
  document.addEventListener('DOMContentLoaded', () => {
    const stickyBar = document.getElementById('mobile-sticky-bar');
    const footer = document.querySelector('footer');
    
    if (stickyBar && footer) {
      window.addEventListener('scroll', () => {
        const footerRect = footer.getBoundingClientRect();
        if (footerRect.top <= window.innerHeight) {
          stickyBar.style.transform = 'translateY(150%)';
        } else {
          stickyBar.style.transform = 'translateY(0)';
        }
      });
    }
  });
</script>
