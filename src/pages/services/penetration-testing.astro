---
import Layout from '../../layouts/Layout.astro';
import ContactSection from '../../components/home/ContactSection.astro';
import { getLangFromUrl } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);

const faq = [
  {
    question: lang === 'en' ? 'What is penetration testing?' : 'পেনেট্রেশন টেস্টিং কী?',
    answer: lang === 'en' ? 'Penetration testing is a simulated cyber attack on your system, performed by ethical hackers, to find security vulnerabilities before real attackers do.' : 'পেনেট্রেশন টেস্টিং হলো এথিক্যাল হ্যাকারদের দিয়ে আপনার সিস্টেমে সিমুলেটেড সাইবার আক্রমণ, যাতে আসল আক্রমণকারীর আগেই দুর্বলতা খুঁজে বের করা যায়।'
  },
  {
    question: lang === 'en' ? 'What types of pentest do you offer?' : 'আপনারা কোন ধরনের পেনটেস্ট অফার করেন?',
    answer: lang === 'en' ? 'We offer Web Application VAPT, Mobile App Security, API Security Testing, Network & Server Vulnerability Assessment, and Social Engineering tests.' : 'আমরা ওয়েব অ্যাপ VAPT, মোবাইল অ্যাপ সিকিউরিটি, API টেস্টিং, নেটওয়ার্ক ভালনারেবিলিটি, এবং সোশ্যাল ইঞ্জিনিয়ারিং টেস্ট অফার করি।'
  },
  {
    question: lang === 'en' ? 'Is it legal and safe?' : 'এটি কি বৈধ ও নিরাপদ?',
    answer: lang === 'en' ? 'Absolutely. We operate under written client authorization following OWASP standards and ethical guidelines. We never access unauthorized systems.' : 'অবশ্যই। আমরা OWASP মানদণ্ড ও নৈতিক নির্দেশিকা অনুসরণ করে লিখিত ক্লায়েন্ট অনুমোদনে কাজ করি। অননুমোদিত সিস্টেমে কখনো প্রবেশ করি না।'
  },
  {
    question: lang === 'en' ? 'What do I receive after the pentest?' : 'পেনটেস্টের পর আমি কী পাব?',
    answer: lang === 'en' ? 'A detailed report with: executive summary, all vulnerabilities found (CVSS scored), risk ratings, proof of concept, and step-by-step remediation guidance.' : 'একটি বিস্তারিত রিপোর্ট: এক্সিকিউটিভ সামারি, সব ভালনারেবিলিটি (CVSS স্কোরসহ), রিস্ক রেটিং, প্রমাণ এবং ধাপে ধাপে সমাধানের গাইড।'
  },
  {
    question: lang === 'en' ? 'Who needs penetration testing?' : 'কাদের পেনেট্রেশন টেস্টিং দরকার?',
    answer: lang === 'en' ? 'Any business with an online presence should test their systems regularly, especially fintech, e-commerce, healthcare, and government agencies. We recommend testing annually or after any major update.' : 'যেকোনো অনলাইন ব্যবসার তাদের সিস্টেম নিয়মিত পরীক্ষা করা উচিত। বিশেষত ফিনটেক, ই-কমার্স, স্বাস্থ্যসেবা ও সরকারি প্রতিষ্ঠানের জন্য এটি বেশি জরুরি। বার্ষিক বা বড় কোনো আপডেটের পর টেস্ট করানো দরকার।'
  }
];
---

<Layout
  title={lang === 'en' ? 'Penetration Testing Bangladesh - Bitsec' : 'পেনেট্রেশন টেস্টিং বাংলাদেশ - Bitsec'}
  description={lang === 'en' ? 'Professional VAPT and penetration testing services in Bangladesh. OWASP-compliant security audits for websites, apps, and networks.' : 'বাংলাদেশে পেশাদার VAPT ও পেনেট্রেশন টেস্টিং। OWASP-সম্মত সিকিউরিটি অডিট।'}
  faqSchema={faq}
>
  <div class="pt-32 pb-16 bg-gradient-to-b from-[#0f1b2d] to-background dark:from-[#0d1117] dark:to-[#0D1117] border-b border-border dark:border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-10">
      <div class="inline-block bg-primary/10 dark:bg-primary/20 text-primary px-4 py-2 rounded-full text-sm font-semibold mb-6">
        🔒 {lang === 'en' ? 'Penetration Testing – Rare in Bangladesh!' : 'পেনেট্রেশন টেস্টিং – বাংলাদেশে বিরল সার্ভিস!'}
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
        {lang === 'en' ? 'Secure Your Digital Assets' : 'আপনার ডিজিটাল সম্পদ সুরক্ষিত করুন'}
      </h1>
      <p class="text-xl text-gray-200 mb-8">
        {lang === 'en'
          ? 'Before attackers find your vulnerabilities, our ethical hackers simulate real attacks to protect your business.'
          : 'আক্রমণকারীরা দুর্বলতা খুঁজে পাওয়ার আগেই আমাদের এথিক্যাল হ্যাকাররা বাস্তব আক্রমণ সিমুলেট করে আপনার ব্যবসা রক্ষা করে।'}}
      </p>
      <a href="/contact" class="inline-flex items-center justify-center bg-primary text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-600 transition-colors shadow-lg shadow-primary/30">
        {lang === 'en' ? 'Start Security Audit' : 'সিকিউরিটি অডিট শুরু করুন'}
      </a>
    </div>
  </div>

  {/* Methodology */}
  <section class="py-24 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-4 text-center">
        {lang === 'en' ? 'Our Methodology' : 'আমাদের পদ্ধতি'}
      </h2>
      <p class="text-center text-text-secondary dark:text-text-secondary mb-14">
        {lang === 'en' ? 'Rigorous, specialized, and actionable 6-step framework' : 'কঠোর, বিশেষায়িত এবং কার্যকরী ৬-ধাপের ফ্রেমওয়ার্ক'}
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { num: '01', icon: '🎯', en: 'Scoping', bn: 'স্কোপিং', enSub: 'Defining targets and rules of engagement.', bnSub: 'লক্ষ্য নির্ধারণ এবং কাজের পরিসর।' },
        { num: '02', icon: '🔍', en: 'Scanning', bn: 'স্ক্যানিং', enSub: 'Automated & manual vulnerability discovery.', bnSub: 'স্বয়ংক্রিয় এবং ম্যানুয়াল দুর্বলতা স্ক্যানিং।' },
        { num: '03', icon: '🛡️', en: 'Exploitation', bn: 'এক্সপ্লয়টেশন', enSub: 'Ethical testing of identified security weaknesses.', bnSub: 'নিরাপত্তা দুর্বলতার নৈতিক টেস্টিং।' },
        { num: '04', icon: '📊', en: 'Analysis', bn: 'বিশ্লেষণ', enSub: 'Reviewing findings and assessing risk levels.', bnSub: 'ফলাফল পর্যালোচনা এবং ঝুঁকির মাত্রা মূল্যায়ন।' },
        { num: '05', icon: '📝', en: 'Reporting', bn: 'রিপোর্টিং', enSub: 'Detailed technical report with actionable fixes.', bnSub: 'সমাধান সহ বিস্তারিত টেকনিক্যাল রিপোর্ট।' },
        { num: '06', icon: '🔧', en: 'Remediation', bn: 'সমাধান', enSub: 'Retesting and guidance for patching vulnerabilities.', bnSub: 'দুর্বলতা সংশোধনের গাইডেন্স এবং রিটেস্টিং।' }
      ].map((step, i) => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border relative" data-animate="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-4xl mb-4">{step.icon}</div>
          <div class="absolute top-4 right-4 text-5xl font-black text-warning/10 leading-none">{step.num}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{lang === 'en' ? step.en : step.bn}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{lang === 'en' ? step.enSub : step.bnSub}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Service types */}
  <section class="py-24 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-14 text-center">
      {lang === 'en' ? 'Our Security Services' : 'আমাদের সিকিউরিটি সার্ভিসমূহ'}
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: '🌐', en: 'Web App VAPT', bn: 'ওয়েব অ্যাপ VAPT', enSub: 'OWASP Top 10, SQL injection, XSS, CSRF and more', bnSub: 'OWASP Top 10, SQL ইনজেকশন, XSS, CSRF আরও অনেক' },
        { icon: '📱', en: 'Mobile App Security', bn: 'মোবাইল অ্যাপ সিকিউরিটি', enSub: 'Android & iOS security assessment and analysis', bnSub: 'Android ও iOS সিকিউরিটি অ্যাসেসমেন্ট' },
        { icon: '🔌', en: 'API Security Testing', bn: 'API সিকিউরিটি টেস্টিং', enSub: 'REST & GraphQL API vulnerability testing', bnSub: 'REST ও GraphQL API ভালনারেবিলিটি টেস্টিং' },
        { icon: '🖧', en: 'Network Assessment', bn: 'নেটওয়ার্ক অ্যাসেসমেন্ট', enSub: 'Server, firewall, and network security review', bnSub: 'সার্ভার, ফায়ারওয়াল ও নেটওয়ার্ক রিভিউ' },
        { icon: '🧠', en: 'Social Engineering', bn: 'সোশ্যাল ইঞ্জিনিয়ারিং', enSub: 'Phishing simulation and employee security awareness', bnSub: 'ফিশিং সিমুলেশন ও কর্মী সচেতনতা' },
        { icon: '📋', en: 'Detailed Report', bn: 'বিস্তারিত রিপোর্ট', enSub: 'CVSS scored vulns, risk rating, remediation plan', bnSub: 'CVSS স্কোর, রিস্ক রেটিং, সমাধানের পরিকল্পনা' },
      ].map(svc => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border hover:border-warning hover:shadow-md transition-all duration-200" data-animate="fade-up">
          <div class="text-3xl mb-4">{svc.icon}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{lang === 'en' ? svc.en : svc.bn}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{lang === 'en' ? svc.enSub : svc.bnSub}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Compliance & Standards */}
  <section class="py-16 bg-surface dark:bg-[var(--theme-surface-2)] border-y border-border dark:border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary dark:text-white text-center mb-10">
        {lang === 'en' ? 'Standards & Compliance' : 'মানদণ্ড ও সম্মতি'}
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        {['OWASP Top 10', 'PTES', 'CVSS 3.1', 'ISO 27001', 'NIST', 'PCI DSS', 'GDPR Aware', 'Ethical Hacking'].map(badge => (
          <span class="bg-white dark:bg-background px-5 py-2.5 rounded-full border border-border dark:border-red-900/40 text-sm font-medium text-text-primary dark:text-gray-200 shadow-sm hover:border-red-500 hover:text-red-400 transition-colors cursor-default">
            {badge}
          </span>
        ))}
      </div>
    </div>
  </section>

  {/* Tools We Use */}
  <section class="py-20 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-text-primary dark:text-white text-center mb-4">
      {lang === 'en' ? 'Tools We Use' : 'আমরা যেসব টুল ব্যবহার করি'}
    </h2>
    <p class="text-center text-text-secondary dark:text-text-secondary mb-12 max-w-xl mx-auto">
      {lang === 'en'
        ? 'Industry-standard tools used by professional security researchers worldwide.'
        : 'বিশ্বের পেশাদার সিকিউরিটি গবেষকদের ব্যবহৃত ইন্ডাস্ট্রি-স্ট্যান্ডার্ড টুলস।'}
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
      {[
        { name: 'Burp Suite', cat: 'Web VAPT', color: 'text-orange-500 bg-orange-50 dark:bg-orange-900/20', path: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
        { name: 'OWASP ZAP', cat: 'Web Scanner', color: 'text-blue-500 bg-blue-50 dark:bg-blue-900/20', path: 'M21 12V7H5a2 2 0 0 1 0-4h14v4M3 15a2 2 0 0 0 2 2h16v-7H5a2 2 0 0 1-2-2z' },
        { name: 'Metasploit', cat: 'Exploitation', color: 'text-red-500 bg-red-50 dark:bg-red-900/20', path: 'M13 10V3L4 14h7v7l9-11h-7z' },
        { name: 'Nmap', cat: 'Network Scan', color: 'text-green-500 bg-green-50 dark:bg-green-900/20', path: 'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18' },
        { name: 'Wireshark', cat: 'Traffic Analysis', color: 'text-teal-500 bg-teal-50 dark:bg-teal-900/20', path: 'M22 12h-4l-3 9L9 3l-3 9H2' },
        { name: 'Kali Linux', cat: 'Pentest OS', color: 'text-purple-500 bg-purple-50 dark:bg-purple-900/20', path: 'M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z' },
      ].map(tool => (
        <div class="flex flex-col items-center text-center p-4 rounded-xl border border-zinc-100 dark:border-zinc-800 hover:shadow-md hover:-translate-y-1 transition-all duration-200 bg-white dark:bg-[#18181b]">
          <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-3 ${tool.color}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d={tool.path}/>
            </svg>
          </div>
          <span class="font-bold text-sm text-text-primary dark:text-white">{tool.name}</span>
          <span class="text-xs text-text-secondary dark:text-text-muted mt-0.5">{tool.cat}</span>
        </div>
      ))}
    </div>
  </section>

  {/* Ethics notice */}
  <section class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="bg-red-500/5 border border-red-500/20 rounded-2xl p-6 md:p-8 flex gap-4 items-start">
      <div class="text-3xl flex-shrink-0">⚖️</div>
      <div>
        <h3 class="font-bold text-text-primary dark:text-white text-lg mb-2">
          {lang === 'en' ? 'Ethics & Legal Compliance' : 'নৈতিকতা ও আইনগত সম্মতি'}
        </h3>
        <p class="text-text-secondary dark:text-text-secondary text-sm leading-relaxed">
          {lang === 'en'
            ? 'We operate strictly within client authorization. All testing is performed ethically under signed Non-Disclosure and Authorization agreements. We never test without explicit written permission.'
            : 'আমরা সম্পূর্ণভাবে ক্লায়েন্টের অনুমোদনের আওতায় কাজ করি। সব টেস্টিং স্বাক্ষরিত NDA এবং অনুমোদন চুক্তির অধীনে নৈতিকভাবে পরিচালিত হয়। লিখিত অনুমতি ছাড়া আমরা কখনো টেস্ট করি না।'}
        </p>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-16 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white text-center mb-14">FAQ</h2>
    <div class="space-y-4">
      {faq.map((item) => (
        <details class="group bg-surface dark:bg-surface rounded-xl border border-border dark:border-border p-5 open:border-warning transition-colors">
          <summary class="flex justify-between items-center cursor-pointer font-semibold text-text-primary dark:text-white list-none">
            {item.question}
            <span class="text-warning text-xl group-open:rotate-180 transition-transform ml-4 flex-shrink-0">+</span>
          </summary>
          <p class="mt-4 text-text-secondary dark:text-text-secondary leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <ContactSection />
</Layout>

<script>
  const animatedEls = document.querySelectorAll('[data-animate="fade-up"]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.style.transitionDelay;
          el.style.transition = `opacity 0.6s ease ${delay}, transform 0.6s ease ${delay}`;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.15 }
  );

  animatedEls.forEach((el) => {
    const htmlEl = el as HTMLElement;
    htmlEl.style.opacity = '0';
    htmlEl.style.transform = 'translateY(32px)';
    // Initial transition without delay to apply the starting state
    htmlEl.style.transition = 'none'; 
    observer.observe(el);
  });
</script>
