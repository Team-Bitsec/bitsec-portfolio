---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
---

<Layout title={lang === 'en' ? 'Contact Us - Bitsec' : 'যোগাযোগ করুন - Bitsec'}>
	<div class="pt-32 pb-16 bg-gradient-to-b from-surface to-background dark:from-[#161B22] dark:to-background border-b border-border dark:border-border">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-10">
			<h1 class="text-4xl md:text-6xl font-bold text-text-primary dark:text-white mb-6">
				{lang === 'en' ? 'Contact Us' : 'যোগাযোগ করুন'}
			</h1>
			<p class="text-xl text-text-secondary dark:text-text-secondary">
				{lang === 'en'
					? 'Have a project in mind? Let\'s talk. We reply within 2 hours.'
					: 'আপনার পরবর্তী প্রজেক্ট নিয়ে আমাদের সাথে আলোচনা করতে চান? আমরা ২ ঘণ্টার মধ্যে রিপ্লাই দিই।'}
			</p>
		</div>
	</div>

	<section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            
            {/* Contact Info */}
            <div>
                <h2 class="text-3xl font-bold text-text-primary dark:text-white mb-8">
                    {lang === 'en' ? 'Get in Touch' : 'আমাদের সাথে কথা বলুন'}
                </h2>
                <div class="space-y-6 mb-10">

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center text-xl flex-shrink-0">✉️</div>
                        <div>
                            <h3 class="font-bold text-text-primary dark:text-white text-lg mb-1">Email</h3>
                            <p class="text-text-secondary dark:text-text-secondary">helpline.bitsec@gmail.com</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center text-xl flex-shrink-0">📞</div>
                        <div>
                            <h3 class="font-bold text-text-primary dark:text-white text-lg mb-1">
                                {lang === 'en' ? 'Phone & WhatsApp' : 'ফোন ও হোয়াটসঅ্যাপ'}
                            </h3>
                            <p class="text-text-secondary dark:text-text-secondary">+880 1805543229</p>
                        </div>
                    </div>

                </div>

                {/* Social Links */}
                <div class="flex gap-3">
                    <!-- LinkedIn -->
                    <a href="https://www.linkedin.com/company/bitsec-it" target="_blank" rel="noopener noreferrer" 
                       class="w-10 h-10 rounded-xl bg-surface dark:bg-surface border border-border dark:border-border flex items-center justify-center text-text-secondary hover:text-[#0A66C2] hover:border-[#0A66C2] transition-colors" aria-label="LinkedIn">
                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                    <!-- YouTube -->
                    <a href="https://www.youtube.com/@BitsecIT" target="_blank" rel="noopener noreferrer" 
                       class="w-10 h-10 rounded-xl bg-surface dark:bg-surface border border-border dark:border-border flex items-center justify-center text-text-secondary hover:text-[#FF0000] hover:border-[#FF0000] transition-colors" aria-label="YouTube">
                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                    <!-- Instagram -->
                    <a href="https://www.instagram.com/bitsecit" target="_blank" rel="noopener noreferrer" 
                       class="w-10 h-10 rounded-xl bg-surface dark:bg-surface border border-border dark:border-border flex items-center justify-center text-text-secondary hover:text-[#E1306C] hover:border-[#E1306C] transition-colors" aria-label="Instagram">
                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
                    </a>
                </div>
            </div>

            {/* Form */}
            <div class="bg-white dark:bg-surface p-8 md:p-10 rounded-2xl border border-border dark:border-border shadow-md">
                <form id="contactForm" class="space-y-5">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label for="name" class="block text-sm font-semibold text-text-primary dark:text-gray-200 mb-2">
                                {lang === 'en' ? 'Your Name *' : 'আপনার নাম *'}
                            </label>
                            <input type="text" id="name" name="name" required
                                class="w-full px-4 py-3 rounded-lg border border-border dark:border-border bg-white dark:bg-background focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-text-primary dark:text-white placeholder:text-slate-400 dark:placeholder:text-text-muted"
                                placeholder={lang === 'en' ? 'John Doe' : 'আপনার নাম'} />
                        </div>
                        <div>
                            <label for="phone" class="block text-sm font-semibold text-text-primary dark:text-gray-200 mb-2">
                                {lang === 'en' ? 'Phone / WhatsApp' : 'ফোন / হোয়াটসঅ্যাপ'}
                            </label>
                            <input type="tel" id="phone" name="phone"
                                class="w-full px-4 py-3 rounded-lg border border-border dark:border-border bg-white dark:bg-background focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-text-primary dark:text-white placeholder:text-slate-400 dark:placeholder:text-text-muted"
                                placeholder="+880 1805543229" />
                        </div>
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-semibold text-text-primary dark:text-gray-200 mb-2">
                            {lang === 'en' ? 'Email Address *' : 'ইমেইল এড্রেস *'}
                        </label>
                        <input type="email" id="email" name="email" required
                            class="w-full px-4 py-3 rounded-lg border border-border dark:border-border bg-white dark:bg-background focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-text-primary dark:text-white placeholder:text-slate-400 dark:placeholder:text-text-muted"
                            placeholder="john@example.com" />
                    </div>

                    <div>
                        <label for="service" class="block text-sm font-semibold text-text-primary dark:text-gray-200 mb-2">
                            {lang === 'en' ? 'Service Needed *' : 'কোন সার্ভিস দরকার? *'}
                        </label>
                        <select id="service" name="service" required
                            class="w-full px-4 py-3 rounded-lg border border-border dark:border-border bg-white dark:bg-background focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-text-primary dark:text-white">
                            <option value="" disabled selected>{lang === 'en' ? 'Select a service...' : 'সার্ভিস বেছে নিন...'}</option>
                            <option value="web">{lang === 'en' ? 'Web Development' : 'ওয়েব ডেভেলপমেন্ট'}</option>
                            <option value="app">{lang === 'en' ? 'App Development' : 'অ্যাপ ডেভেলপমেন্ট'}</option>
                            <option value="design">{lang === 'en' ? 'Graphics Design' : 'গ্রাফিক্স ডিজাইন'}</option>
                            <option value="pentest">{lang === 'en' ? 'Penetration Testing' : 'পেনেট্রেশন টেস্টিং'}</option>
                            <option value="multiple">{lang === 'en' ? 'Multiple Services' : 'একাধিক সার্ভিস'}</option>
                            <option value="other">{lang === 'en' ? 'Other / Not Sure' : 'অন্য / জানি না'}</option>
                        </select>
                    </div>



                    <div>
                        <label for="message" class="block text-sm font-medium text-text-primary dark:text-white mb-2">
                            {lang === 'en' ? 'Your Message *' : 'আপনার মেসেজ *'}
                        </label>
                        <textarea id="message" name="message" rows="4" required
                            class="w-full px-4 py-3 rounded-lg border border-border dark:border-border bg-white dark:bg-background focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-text-primary dark:text-white placeholder:text-slate-400 dark:placeholder:text-text-muted"
                            placeholder={lang === 'en' ? 'Tell us about your project...' : 'আপনার প্রজেক্ট সম্পর্কে বলুন...'}></textarea>
                    </div>

                    <div id="formStatus" class="hidden"></div>

                    <button type="submit" id="submitBtn"
                        class="w-full py-4 bg-gradient-to-r from-[#0057FF] to-[#00C2A8] text-white font-bold rounded-lg hover:from-[#0040C0] hover:to-[#009980] active:scale-95 transition-all duration-200 shadow-lg shadow-[#0057FF]/30 hover:shadow-[#0057FF]/50 hover:scale-[1.01] flex items-center justify-center gap-2">
                        <span id="submitText">{lang === 'en' ? '📩 Send Message' : '📩 মেসেজ পাঠান'}</span>
                    </button>
                </form>
            </div>
        </div>
	</section>

    {/* Mobile Sticky WhatsApp */}
    <div class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-[#25D366] px-4 py-3 shadow-2xl">
        <a href="https://wa.me/8801805543229" target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-3 text-white font-bold text-base">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {lang === 'en' ? 'Chat on WhatsApp' : 'হোয়াটসঅ্যাপে চ্যাট করুন'}
        </a>
    </div>

    <script>
        const form = document.getElementById('contactForm') as HTMLFormElement;
        const statusEl = document.getElementById('formStatus') as HTMLDivElement;
        const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
        const submitText = document.getElementById('submitText') as HTMLSpanElement;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
            submitText.textContent = '⏳ Sending...';

            // Simulate success (replace with EmailJS call when keys are ready)
            await new Promise(resolve => setTimeout(resolve, 1200));

            // Persistent success state — hide form, show success message
            form.classList.add('hidden');
            statusEl.className = 'flex flex-col items-center justify-center gap-4 py-12 text-center';
            statusEl.innerHTML = `
              <div class="w-16 h-16 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-3xl shadow-md">✅</div>
              <h3 class="text-xl font-bold text-text-primary dark:text-white">Message Sent!</h3>
              <p class="text-text-secondary dark:text-gray-400 max-w-xs">We received your message and will reply within <strong>2 hours</strong>. Check your email inbox.</p>
              <button onclick="window.location.reload()" class="mt-2 text-sm text-primary hover:underline">Send another message</button>
            `;
        });
    </script>
</Layout>
