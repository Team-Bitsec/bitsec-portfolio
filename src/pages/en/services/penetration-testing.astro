---
import Layout from '../../../layouts/Layout.astro';
import ContactSection from '../../../components/home/ContactSection.astro';

const faq = [
  { question: 'What is VAPT?', answer: 'Vulnerability Assessment and Penetration Testing (VAPT) is a comprehensive security auditing process where we actively search for and attempt to exploit network and application flaws.' },
  { question: 'Will testing disrupt our business operations?', answer: 'No. Our testing methodologies are designed to be minimally invasive. We verify vulnerabilities safely without causing downtime or data loss.' },
  { question: 'Do you provide help with fixing the issues?', answer: 'Yes. Our reports include clear, actionable remediation steps for developers. We can also schedule a re-test to verify the patches.' },
  { question: 'How often should we perform security testing?', answer: 'We recommend comprehensive auditing at least once a year, as well as after any major infrastructure changes, feature releases, or architecture updates.' },
  { question: 'Are your security experts certified?', answer: 'Yes! Our team holds industry-recognized certifications and strictly follows ethical hacking standards to ensure authoritative, reliable testing.' }
];
---

<Layout title="Penetration Testing Services - Bitsec" description="Advanced Security Audits to ensure impenetrable security for your web applications." faqSchema={faq}>
  <div class="pt-32 pb-16 bg-gradient-to-b from-surface to-background dark:from-surface dark:to-background border-b border-border dark:border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-10">
      <div class="inline-block bg-primary/10 dark:bg-primary/20 text-primary px-4 py-2 rounded-full text-sm font-semibold mb-6">Penetration Testing</div>
      <h1 class="text-4xl md:text-6xl font-bold text-text-primary dark:text-white mb-6">Advanced Security Audits</h1>
      <p class="text-xl text-text-secondary dark:text-text-secondary mb-8">Ensure impenetrable security for your applications and safeguard your data from hackers.</p>
      <a href="/en/contact" class="inline-flex items-center justify-center bg-primary text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-600 transition-colors shadow-lg shadow-primary/30">Start Security Audit</a>
    </div>
  </div>

  <section class="py-24 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-4 text-center">Our Methodology</h2>
      <p class="text-center text-text-secondary dark:text-text-secondary mb-14">Rigorous, specialized, and actionable 6-step framework</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { num: '01', icon: '🎯', title: 'Scoping', sub: 'Defining targets and rules of engagement.' },
        { num: '02', icon: '🔍', title: 'Scanning', sub: 'Automated & manual vulnerability discovery.' },
        { num: '03', icon: '🛡️', title: 'Exploitation', sub: 'Ethical testing of identified security weaknesses.' },
        { num: '04', icon: '📊', title: 'Analysis', sub: 'Reviewing findings and assessing risk levels.' },
        { num: '05', icon: '📝', title: 'Reporting', sub: 'Detailed technical report with actionable fixes.' },
        { num: '06', icon: '🔧', title: 'Remediation', sub: 'Retesting and guidance for patching vulnerabilities.' }
      ].map((step, i) => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border relative" data-animate="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-4xl mb-4">{step.icon}</div>
          <div class="absolute top-4 right-4 text-5xl font-black text-warning/10 leading-none">{step.num}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{step.title}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{step.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="pb-24 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-14 text-center">Our Security Services</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: '🌐', title: 'Web App VAPT', sub: 'OWASP Top 10, SQL injection, XSS, CSRF and more' },
        { icon: '📱', title: 'Mobile App Security', sub: 'Android & iOS security assessment and analysis' },
        { icon: '🔌', title: 'API Security Testing', sub: 'REST & GraphQL API vulnerability testing' },
        { icon: '🖧', title: 'Network Assessment', sub: 'Server, firewall, and network security review' },
        { icon: '🧠', title: 'Social Engineering', sub: 'Phishing simulation and employee security awareness' },
        { icon: '📋', title: 'Detailed Report', sub: 'CVSS scored vulns, risk rating, remediation plan' },
      ].map((svc, i) => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border hover:border-warning hover:shadow-md transition-all duration-200" data-animate="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-4xl mb-4">{svc.icon}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{svc.title}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{svc.sub}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Compliance & Standards */}
  <section class="py-16 bg-surface dark:bg-[var(--theme-surface-2)] border-y border-border dark:border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary dark:text-white text-center mb-10">
        Standards & Compliance
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        {['OWASP Top 10', 'PTES', 'CVSS 3.1', 'ISO 27001', 'NIST', 'PCI DSS', 'GDPR Aware', 'Ethical Hacking'].map(badge => (
          <span class="bg-white dark:bg-background px-5 py-2.5 rounded-full border border-border dark:border-red-900/40 text-sm font-medium text-text-primary dark:text-gray-200 shadow-sm hover:border-red-500 hover:text-red-400 transition-colors cursor-default">
            {badge}
          </span>
        ))}
      </div>
    </div>
  </section>

  {/* Tools We Use */}
  <section class="py-20 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-text-primary dark:text-white text-center mb-4">
      Tools We Use
    </h2>
    <p class="text-center text-text-secondary dark:text-text-secondary mb-12 max-w-xl mx-auto">
      Industry-standard tools used by professional security researchers worldwide.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
      {[
        { name: 'Burp Suite', cat: 'Web VAPT', color: 'text-orange-500 bg-orange-50 dark:bg-orange-900/20', path: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
        { name: 'OWASP ZAP', cat: 'Web Scanner', color: 'text-blue-500 bg-blue-50 dark:bg-blue-900/20', path: 'M21 12V7H5a2 2 0 0 1 0-4h14v4M3 15a2 2 0 0 0 2 2h16v-7H5a2 2 0 0 1-2-2z' },
        { name: 'Metasploit', cat: 'Exploitation', color: 'text-red-500 bg-red-50 dark:bg-red-900/20', path: 'M13 10V3L4 14h7v7l9-11h-7z' },
        { name: 'Nmap', cat: 'Network Scan', color: 'text-green-500 bg-green-50 dark:bg-green-900/20', path: 'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18' },
        { name: 'Wireshark', cat: 'Traffic Analysis', color: 'text-teal-500 bg-teal-50 dark:bg-teal-900/20', path: 'M22 12h-4l-3 9L9 3l-3 9H2' },
        { name: 'Kali Linux', cat: 'Pentest OS', color: 'text-purple-500 bg-purple-50 dark:bg-purple-900/20', path: 'M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z' },
      ].map(tool => (
        <div class="flex flex-col items-center text-center p-4 rounded-xl border border-zinc-100 dark:border-zinc-800 hover:shadow-md hover:-translate-y-1 transition-all duration-200 bg-white dark:bg-[#18181b]">
          <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-3 ${tool.color}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d={tool.path}/>
            </svg>
          </div>
          <span class="font-bold text-sm text-text-primary dark:text-white">{tool.name}</span>
          <span class="text-xs text-text-secondary dark:text-text-muted mt-0.5">{tool.cat}</span>
        </div>
      ))}
    </div>
  </section>

  {/* Ethics notice */}
  <section class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="bg-red-500/5 border border-red-500/20 rounded-2xl p-6 md:p-8 flex gap-4 items-start">
      <div class="text-3xl flex-shrink-0">⚖️</div>
      <div>
        <h3 class="font-bold text-text-primary dark:text-white text-lg mb-2">
          Ethics & Legal Compliance
        </h3>
        <p class="text-text-secondary dark:text-text-secondary text-sm leading-relaxed">
          We operate strictly within client authorization. All testing is performed ethically under signed Non-Disclosure and Authorization agreements. We never test without explicit written permission.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-text-primary dark:text-white text-center mb-14">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.map(item => (
        <details class="group bg-surface dark:bg-surface rounded-xl border border-border dark:border-border p-5 open:border-warning">
          <summary class="flex justify-between items-center cursor-pointer font-semibold text-text-primary dark:text-white list-none">
            {item.question}<span class="text-warning text-xl group-open:rotate-180 transition-transform ml-4 flex-shrink-0">+</span>
          </summary>
          <p class="mt-4 text-text-secondary dark:text-text-secondary leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
  <ContactSection />
</Layout
