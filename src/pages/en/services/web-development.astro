---
// This page now redirects to the bilingual BN page which detects lang via URL
// The BN service page uses getLangFromUrl, so EN version mirrors full content
import Layout from '../../../layouts/Layout.astro';
import ContactSection from '../../../components/home/ContactSection.astro';

const faq = [
  { question: 'How long does it take to build a website?', answer: 'A basic website takes 2-3 weeks. A complex e-commerce or web app typically takes 6-10 weeks depending on requirements.' },
  { question: 'What technologies do you use?', answer: 'We primarily use React, Next.js, Astro and also support WordPress, Laravel based on client needs.' },
  { question: 'Do you provide SEO optimization?', answer: 'Yes! Every website we build is SEO-optimized from day one. That means fast load times, proper meta tags, schema markup, and mobile-first design.' },
  { question: 'Will my website work on mobile?', answer: 'Absolutely. We follow mobile-first design principles, so your site looks perfect on phones, tablets, and desktops.' },
  { question: 'Do you offer post-launch support?', answer: 'Yes, we offer 1-6 months of free maintenance depending on the package, and ongoing support plans are available.' }
];
---

<Layout title="Web Development Bangladesh - Bitsec" description="Top web development company in Bangladesh. We build SEO-ready, ultra-fast websites using Next.js, React, and Astro." faqSchema={faq}>
  <div class="pt-32 pb-16 bg-gradient-to-b from-surface to-background dark:from-surface dark:to-background border-b border-border dark:border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-10">
      <div class="inline-block bg-primary/10 dark:bg-primary/20 text-primary px-4 py-2 rounded-full text-sm font-semibold mb-6">Web Development</div>
      <h1 class="text-4xl md:text-6xl font-bold text-text-primary dark:text-white mb-6">Websites That Drive Results</h1>
      <p class="text-xl text-text-secondary dark:text-text-secondary mb-8">We build ultra-fast, SEO-optimized, visually stunning websites that convert visitors into paying customers.</p>
      <a href="/en/contact" class="inline-flex items-center justify-center bg-primary text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-600 transition-colors shadow-lg shadow-primary/30">Start Your Project</a>
    </div>
  </div>

  <section class="py-24 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-4 text-center">Our Process</h2>
      <p class="text-center text-text-secondary dark:text-text-secondary mb-14">Simple, transparent, and proven 6-step process</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { num: '01', icon: '🎯', title: 'Discovery', sub: 'Understanding your goals and requirements.' },
        { num: '02', icon: '📋', title: 'Planning', sub: 'Project roadmap and timeline.' },
        { num: '03', icon: '🎨', title: 'Design', sub: 'Figma mockups and interactive prototypes.' },
        { num: '04', icon: '⚡', title: 'Development', sub: 'Fast, clean code with SEO built-in.' },
        { num: '05', icon: '🧪', title: 'Testing', sub: 'Rigorous QA and performance testing.' },
        { num: '06', icon: '🚀', title: 'Launch', sub: 'Deployment and project handover.' }
      ].map((step, i) => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border relative" data-animate="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-4xl mb-4">{step.icon}</div>
          <div class="absolute top-4 right-4 text-5xl font-black text-primary/10 leading-none">{step.num}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{step.title}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{step.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="pb-24 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-4 text-center">What We Build</h2>
      <p class="text-center text-text-secondary dark:text-text-secondary mb-14">Scalable and fast web experiences</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: '🏢', title: 'Corporate Sites', sub: 'Professional websites for businesses.' },
        { icon: '🛒', title: 'E-Commerce', sub: 'High-converting online stores.' },
        { icon: '🌩️', title: 'SaaS Platforms', sub: 'Scalable cloud-based applications.' },
        { icon: '📰', title: 'Blogs & News', sub: 'Content-rich editorial platforms.' },
        { icon: '👨‍💻', title: 'Portfolios', sub: 'Showcases for agencies and freelancers.' },
        { icon: '⚡', title: 'Landing Pages', sub: 'Fast, optimized campaign pages.' }
      ].map((cat, i) => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border hover:border-primary hover:shadow-md transition-all duration-200" data-animate="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-4xl mb-4">{cat.icon}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{cat.title}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{cat.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-16 bg-surface dark:bg-[var(--theme-surface-2)] border-y border-border dark:border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary dark:text-white text-center mb-10">Technologies We Use</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {['React', 'Next.js', 'Astro', 'TypeScript', 'WordPress', 'Laravel', 'Tailwind CSS', 'Node.js', 'PostgreSQL', 'Vercel'].map(tech => (
          <span class="bg-white dark:bg-background px-5 py-2.5 rounded-full border border-border dark:border-border text-sm font-medium text-text-primary dark:text-gray-200 shadow-sm hover:border-primary hover:text-primary transition-colors">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-text-primary dark:text-white text-center mb-14">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.map(item => (
        <details class="group bg-surface dark:bg-surface rounded-xl border border-border dark:border-border p-5 open:border-primary">
          <summary class="flex justify-between items-center cursor-pointer font-semibold text-text-primary dark:text-white list-none">
            {item.question}<span class="text-primary text-xl group-open:rotate-180 transition-transform ml-4 flex-shrink-0">+</span>
          </summary>
          <p class="mt-4 text-text-secondary dark:text-text-secondary leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
  <ContactSection />
</Layout>

<script>
  const animatedEls = document.querySelectorAll('[data-animate="fade-up"]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.style.transitionDelay;
          el.style.transition = `opacity 0.6s ease ${delay}, transform 0.6s ease ${delay}`;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.15 }
  );

  animatedEls.forEach((el) => {
    const htmlEl = el as HTMLElement;
    htmlEl.style.opacity = '0';
    htmlEl.style.transform = 'translateY(32px)';
    // Initial transition without delay to apply the starting state
    htmlEl.style.transition = 'none'; 
    observer.observe(el);
  });
</script>
