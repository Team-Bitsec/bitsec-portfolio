---
import Layout from '../../../layouts/Layout.astro';
import ContactSection from '../../../components/home/ContactSection.astro';

const faq = [
  { question: 'What types of design services do you offer?', answer: 'We offer a wide range of services including UI/UX design, brand identity (logos, guidelines), marketing materials, social media graphics, and product packaging.' },
  { question: 'Will I receive the source files?', answer: 'Yes, absolutely. Upon project completion, we provide all original, editable source files (Figma, AI, PSD, etc.) and optimized export formats.' },
  { question: 'How many revisions can I request?', answer: 'We typically offer multiple rounds of revisions based on the selected package to ensure you are completely satisfied with the final result.' },
  { question: 'What is the standard turnaround time?', answer: 'Simple graphics like social media posts can take 1-3 days, while comprehensive UI/UX or brand identities may take 2-4 weeks.' },
  { question: 'Do you design for both print and digital?', answer: 'Yes! We create pixel-perfect digital assets for the web, as well as high-resolution, print-ready files for physical materials.' }
];
---

<Layout title="Graphics Design Services - Bitsec" description="Stunning visuals & branding. Creative design that perfectly encapsulates your brand identity." faqSchema={faq}>
  <div class="pt-32 pb-16 bg-gradient-to-b from-surface to-background dark:from-surface dark:to-background border-b border-border dark:border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-10">
      <div class="inline-block bg-primary/10 dark:bg-primary/20 text-primary px-4 py-2 rounded-full text-sm font-semibold mb-6">Graphics Design</div>
      <h1 class="text-4xl md:text-6xl font-bold text-text-primary dark:text-white mb-6">Stunning Visuals & Branding</h1>
      <p class="text-xl text-text-secondary dark:text-text-secondary mb-8">Creative design that perfectly encapsulates and projects your brand identity.</p>
      <a href="/en/contact" class="inline-flex items-center justify-center bg-primary text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-600 transition-colors shadow-lg shadow-primary/30">Get Free Quote</a>
    </div>
  </div>

  <section class="py-24 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-4 text-center">Our Process</h2>
      <p class="text-center text-text-secondary dark:text-text-secondary mb-14">Simple, transparent, and proven 6-step process</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { num: '01', icon: '🎯', title: 'Briefing', sub: 'Understanding your brand, audience, and vision.' },
        { num: '02', icon: '💡', title: 'Concept', sub: 'Brainstorming ideas, sketches, and moodboards.' },
        { num: '03', icon: '🎨', title: 'Design', sub: 'Creating high-fidelity drafts and concepts.' },
        { num: '04', icon: '🔄', title: 'Revisions', sub: 'Refining and perfecting based on your feedback.' },
        { num: '05', icon: '✅', title: 'Finalization', sub: 'Preparing all assets across required platforms.' },
        { num: '06', icon: '📦', title: 'Delivery', sub: 'Handing over all final, editable source files.' }
      ].map((step, i) => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border relative" data-animate="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-4xl mb-4">{step.icon}</div>
          <div class="absolute top-4 right-4 text-5xl font-black text-primary/10 leading-none">{step.num}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{step.title}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{step.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="pb-24 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white mb-4 text-center">What We Design</h2>
      <p class="text-center text-text-secondary dark:text-text-secondary mb-14">Results that speak for themselves</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: '🎯', title: 'Logo Design', sub: 'Memorable marks that define your brand.' },
        { icon: '🏢', title: 'Brand Identity', sub: 'Cohesive guidelines and brand systems.' },
        { icon: '📱', title: 'Social Media', sub: 'Engaging banners and promotional graphics.' },
        { icon: '🖨️', title: 'Print Design', sub: 'High-quality brochures, cards, and flyers.' },
        { icon: '📦', title: 'Packaging', sub: 'Product packaging that stands out on shelves.' },
        { icon: '🖥️', title: 'UI Design', sub: 'Intuitive and beautiful user interfaces.' }
      ].map((cat, i) => (
        <div class="bg-surface dark:bg-surface p-6 rounded-2xl border border-border dark:border-border hover:border-primary hover:shadow-md transition-all duration-200" data-animate="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-4xl mb-4">{cat.icon}</div>
          <h3 class="text-lg font-bold text-text-primary dark:text-white mb-2">{cat.title}</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary">{cat.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-16 bg-surface dark:bg-[var(--theme-surface-2)] border-y border-border dark:border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary dark:text-white text-center mb-10">Tools We Master</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {['Figma', 'Adobe Illustrator', 'Adobe Photoshop', 'Adobe After Effects', 'Adobe InDesign', 'Canva', 'Spline', 'Framer', 'Sketch', 'Miro'].map(tech => (
          <span class="bg-white dark:bg-background px-5 py-2.5 rounded-full border border-border dark:border-border text-sm font-medium text-text-primary dark:text-gray-200 shadow-sm hover:border-primary hover:text-primary transition-colors">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-text-primary dark:text-white text-center mb-14">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.map(item => (
        <details class="group bg-surface dark:bg-surface rounded-xl border border-border dark:border-border p-5 open:border-primary">
          <summary class="flex justify-between items-center cursor-pointer font-semibold text-text-primary dark:text-white list-none">
            {item.question}<span class="text-primary text-xl group-open:rotate-180 transition-transform ml-4 flex-shrink-0">+</span>
          </summary>
          <p class="mt-4 text-text-secondary dark:text-text-secondary leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
  <ContactSection />
</Layout>

<script>
  const animatedEls = document.querySelectorAll('[data-animate="fade-up"]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.style.transitionDelay;
          el.style.transition = `opacity 0.6s ease ${delay}, transform 0.6s ease ${delay}`;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.15 }
  );

  animatedEls.forEach((el) => {
    const htmlEl = el as HTMLElement;
    htmlEl.style.opacity = '0';
    htmlEl.style.transform = 'translateY(32px)';
    // Initial transition without delay to apply the starting state
    htmlEl.style.transition = 'none'; 
    observer.observe(el);
  });
</script>
