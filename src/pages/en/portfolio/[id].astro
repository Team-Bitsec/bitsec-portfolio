---
import { doc, getDoc, collection, getDocs } from 'firebase/firestore';
import { db } from '../../../lib/firebase';
import Layout from '../../../layouts/Layout.astro';
import ContactSection from '../../../components/home/ContactSection.astro';

export async function getStaticPaths() {
  const paths: any[] = [];
  try {
    const querySnapshot = await getDocs(collection(db, 'projects'));
    querySnapshot.forEach((doc) => {
      paths.push({
        params: { id: doc.id },
        props: { projectId: doc.id },
      });
    });
  } catch (error) {
    console.error("Error fetching project paths:", error);
  }
  return paths;
}

const { projectId } = Astro.props;

let entry: any = null;
try {
  const docRef = doc(db, 'projects', projectId);
  const docSnap = await getDoc(docRef);
  if (docSnap.exists()) {
    entry = { id: docSnap.id, ...docSnap.data() };
  }
} catch (error) {
  console.error("Error fetching project details:", error);
}

if (!entry) {
  return Astro.redirect('/404');
}
---

<Layout title={`${entry.title} - Portfolio | Bitsec`}>
	<div class="pt-32 pb-16 bg-gradient-to-b from-surface to-background dark:from-[#161B22] dark:to-background border-b border-border dark:border-border">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
			<div class="mb-6 flex flex-wrap items-center gap-4 text-sm font-medium">
				<span class="text-primary bg-primary/10 px-3 py-1 rounded-full">{entry.category}</span>
				{entry.link && (
					<a href={entry.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white bg-primary hover:bg-blue-600 px-4 py-1.5 rounded-full transition-colors font-semibold shadow-sm shadow-primary/20">
						Visit Live Project
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
							<polyline points="15 3 21 3 21 9"></polyline>
							<line x1="10" y1="14" x2="21" y2="3"></line>
						</svg>
					</a>
				)}
			</div>
			<h1 class="text-4xl md:text-5xl font-bold text-text-primary dark:text-white mb-8">{entry.title}</h1>
			<div class="relative aspect-video w-full rounded-2xl overflow-hidden shadow-lg border border-border dark:border-border bg-gray-100 dark:bg-zinc-800">
				{entry.category && entry.category.toLowerCase().includes('app') && (
					<img 
						src={entry.image} 
						alt="" 
						class="absolute inset-0 w-full h-full object-cover blur-3xl opacity-60 scale-125 saturate-150"
						aria-hidden="true"
					/>
				)}
				<img 
					src={entry.image} 
					alt={entry.title} 
					loading="lazy" 
					decoding="async" 
					class={`absolute inset-0 w-full h-full ${entry.category && entry.category.toLowerCase().includes('app') ? 'object-contain p-4 md:p-8 drop-shadow-2xl z-10' : 'object-cover'}`} 
				/>
			</div>
		</div>
	</div>

	<section class="py-16 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="prose prose-lg dark:prose-invert max-w-none text-text-secondary dark:text-gray-300">
			<p>{entry.description}</p>
		</div>

		{entry.screenshots && entry.screenshots.length > 0 && (
			<div class="mt-16">
				<h2 class="text-2xl md:text-3xl font-bold text-text-primary dark:text-white mb-8">Project Gallery</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
					{entry.screenshots.map((screenshot: string) => (
						<div class="group overflow-hidden rounded-2xl shadow-sm border border-border dark:border-border bg-gray-50 dark:bg-zinc-800/50">
							<img 
								src={screenshot} 
								alt={`${entry.title} screenshot`} 
								loading="lazy" 
								class="w-full rounded-2xl group-hover:scale-105 transition-transform duration-700 ease-[0.33,1,0.68,1]" 
							/>
						</div>
					))}
				</div>
			</div>
		)}
	</section>

	<ContactSection />
</Layout>
