---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/home/Hero';
import TrustBar from '../../components/home/TrustBar';
import ServicesPreview from '../../components/home/ServicesPreview.astro';
import HowWeWork from '../../components/home/HowWeWork.astro';
import PortfolioFilter from '../../components/home/PortfolioFilter';
import TestimonialsCarousel from '../../components/home/TestimonialsCarousel';
import BlogPreview from '../../components/home/BlogPreview.astro';
import FreeConsultation from '../../components/home/FreeConsultation.astro';
import ContactSection from '../../components/home/ContactSection.astro';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

const t = useTranslations('en');
const translatePath = useTranslatedPath('en');
---

<Layout title="Bitsec - Top Digital Agency in Bangladesh | Web, App, Pentest">
	<Hero 
		client:load 
		lang="en"
		title={t('hero.title')}
		subtitle={t('hero.subtitle')}
		primaryCta={t('hero.cta.primary')}
		secondaryCta={t('hero.cta.secondary')}
		primaryLink="/en/contact"
		secondaryLink="/en/portfolio"
	/>
	<TrustBar client:visible lang="en" />
	<ServicesPreview />
	<HowWeWork />
	<PortfolioFilter client:visible lang="en" portfolioPath={translatePath('/portfolio')} />
	<TestimonialsCarousel client:visible lang="en" />
	<FreeConsultation />
	<BlogPreview />
	<ContactSection />
</Layout>
